<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.symphony.task-runner-health</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/python3</string>
    <string>/Users/bob/AI-Server/ops/task_runner_health.py</string>
    <string>--quiet</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>AI_SERVER_ROOT</key>
    <string>/Users/bob/AI-Server</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>

  <key>StartInterval</key>
  <integer>900</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>WorkingDirectory</key>
  <string>/Users/bob/AI-Server</string>

  <key>StandardOutPath</key>
  <string>/Users/bob/AI-Server/data/task_runner/health.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/bob/AI-Server/data/task_runner/health.err.log</string>
</dict>
</plist>
