# =============================================================================
# Symphony Smart Homes — AI-Server Environment Variables
# Host: Bob (Mac Mini M4, Apple Silicon)
#
# USAGE:
#   cp .env.example .env
#   nano .env          # Fill in every value marked REQUIRED
#   ./start_symphony.sh
#
# SECURITY:
#   • Never commit .env to version control
#   • Restrict file permissions:  chmod 600 .env
#   • Rotate all tokens immediately if this file is ever exposed
#
# SECTIONS:
#   1. Global / Environment
#   2. AI Model Keys
#   3. Redis
#   4. Ollama (external — Maestro)
#   5. Voice Receptionist (Twilio)
#   6. D-Tools Cloud
#   7. Telegram Bot
#   8. Home Assistant & MQTT
#   9. Per-service Log Levels
# =============================================================================


# -----------------------------------------------------------------------------
# 1. GLOBAL / ENVIRONMENT
# -----------------------------------------------------------------------------

# Runtime environment. Set to "production" on Bob. Use "development" locally.
# Default: production
NODE_ENV=production

# API bind hosts: keep localhost by default (Tailscale/reverse proxy recommended)
# MOBILE_API_BIND_HOST=127.0.0.1
# TRADING_API_BIND_HOST=127.0.0.1

# API auth token required by mobile_api/trading_api for non-health endpoints.
# Use a long random value. Clients send:
#   X-Symphony-Token: <token>
#   or Authorization: Bearer <token>
# SYMPHONY_API_TOKEN=replace_with_long_random_token

# CORS allowlist (comma-separated origins) for app/API access.
# MOBILE_APP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://bobs-mac-mini:8420,http://bobs-mac-mini:8421

# Symphony Markup — HTTPS via Tailscale (enables Share → Save to Files on iPad)
# Run: tailscale serve 8091
# Then set this to the URL Tailscale prints (e.g. https://bobs-mac-mini.your-tailnet.ts.net)
# MARKUP_HTTPS_URL=https://bobs-mac-mini.your-tailnet.ts.net

# Network Guard daemon (gateway + optional Control4 monitoring)
# Default gateway target for ping checks.
# NETWORK_GUARD_GATEWAY=192.168.1.1
# Optional Control4 controller host/IP to monitor specifically.
# NETWORK_GUARD_CONTROL4_HOST=192.168.1.50
# DNS and web probes to identify "internet works partially" events.
# NETWORK_GUARD_DNS_TEST_HOST=google.com
# NETWORK_GUARD_HTTP_TEST_URL=http://connectivitycheck.gstatic.com/generate_204
# Check cadence (seconds). launchd StartInterval should generally match.
# NETWORK_GUARD_INTERVAL_SEC=120
# Alert cooldown to avoid noisy repeats when issue fingerprint is unchanged.
# NETWORK_GUARD_ALERT_COOLDOWN_SECONDS=900
# Consecutive bad checks required before creating/updating incident + alert.
# NETWORK_GUARD_CONSECUTIVE_BAD_REQUIRED=2
# Thresholds
# NETWORK_GUARD_LOSS_WARN_PCT=5
# NETWORK_GUARD_LOSS_CRIT_PCT=20
# NETWORK_GUARD_JITTER_WARN_MS=25
# NETWORK_GUARD_JITTER_CRIT_MS=60
# NETWORK_GUARD_AVG_LATENCY_WARN_MS=40
# NETWORK_GUARD_AVG_LATENCY_CRIT_MS=120


# -----------------------------------------------------------------------------
# 2. AI MODEL KEYS
# -----------------------------------------------------------------------------

# OpenAI API key — used by openclaw and voice-receptionist
# Get it at: https://platform.openai.com/api-keys
# REQUIRED
OPENAI_API_KEY=sk-...

# Perplexity API key — used by trading market intelligence research.
# Required for primary research provider in tools/market_intel.py.
PERPLEXITY_API_KEY=pplx-...

# Backup model for market_intel fallback chain (Perplexity -> web/local -> OpenAI backup).
# Default: gpt-4.1-mini
# OPENAI_BACKUP_MODEL=gpt-4.1-mini

# market_intel local budget controls (env-driven; conservative throttles removed).
# Defaults: monthly=5000, daily=200, enforcement disabled.
# PERPLEXITY_MONTHLY_QUERY_LIMIT=5000
# PERPLEXITY_DAILY_QUERY_TARGET=200
# PERPLEXITY_ENFORCE_LOCAL_BUDGET=false

# Fallback behavior controls for market_intel.
# MARKET_INTEL_ENABLE_WEB_FALLBACK=true
# MARKET_INTEL_ENABLE_BACKUP_MODEL=true

# Anthropic API key — used by openclaw (Conductor Claude model)
# Get it at: https://console.anthropic.com/settings/keys
# REQUIRED
ANTHROPIC_API_KEY=sk-ant-...

# The primary conductor model OpenClaw uses for orchestration decisions.
# Recommended: claude-3-5-sonnet-20241022  (best cost/performance balance)
# Options: claude-3-opus-20240229 | claude-3-5-sonnet-20241022 | gpt-4o | gpt-4-turbo
# Default: claude-3-5-sonnet-20241022
CONDUCTOR_MODEL=claude-3-5-sonnet-20241022


# -----------------------------------------------------------------------------
# 3. REDIS
# -----------------------------------------------------------------------------

# Redis is configured internally — no external env vars needed.
# REDIS_URL is injected into each service automatically as redis://redis:6379
# This section is informational only.


# -----------------------------------------------------------------------------
# 4. OLLAMA — External service on Maestro (64GB iMac)
# -----------------------------------------------------------------------------

# Full URL to the Ollama instance running on Maestro (64GB iMac).
# Maestro must be on the same LAN as Bob, or accessible via tailscale/VPN.
# Format: http://<MAESTRO_IP>:11434
# Tip: Assign Maestro a static LAN IP via your router's DHCP reservations.
# Available models: llama3.1:8b, qwen3:8b
# Used by: link analysis, knowledge scanner, ClawWork agent, D-Tools agent
# REQUIRED if using local models
OLLAMA_HOST=http://192.168.1.199:11434

# LM Studio (OpenAI-compatible local inference). Default: http://localhost:1234
# LM_STUDIO_URL=http://localhost:1234
# LM Studio policy: ondemand (recommended) or always_on
# LM_STUDIO_MODE=ondemand
# Optional LM Studio CLI path used for on-demand start/stop.
# LM_STUDIO_CLI=/Applications/LM Studio.app/Contents/Resources/app/.webpack/lms

# Ollama keep-alive controls how long model stays loaded after request.
# Lower = less idle RAM usage, slightly higher cold-start latency.
# Examples: 30s, 2m, 5m, 0 (unload quickly)
# OLLAMA_KEEP_ALIVE=2m


# -----------------------------------------------------------------------------
# 4b. HARPA — Betty's browser automation bridge
# -----------------------------------------------------------------------------

# Betty runs bob_harpa_bridge, which talks to HARPA Chrome extension.
# Bob calls Betty's bridge at port 9090 for D-Tools automation.
# dtool_cloud_client and proposals use these.
HARPA_PRIMARY_URL=http://192.168.1.XXX:9090
# Optional: Beatrice (8GB iMac) as fallback when you add it
# HARPA_FALLBACK_URL=http://192.168.1.XXX:9090

# Optional: M2 MacBook (travel) — use Tailscale hostname when away
# M2_OLLAMA_URL=http://m2-macbook:11434
# M2_HARPA_URL=http://m2-macbook:9090

# Optional: Bill (2012 Mac mini 16GB) — 3B, embed, HARPA only
# BILL_OLLAMA_URL=http://bill:11434
# BILL_HARPA_URL=http://bill:9090

# HARPA Grid API key from Chrome > HARPA Settings > Grid
# Same key used in Betty's bridge plist (com.symphony.harpa-bridge)
HARPA_GRID_API_KEY=your_harpa_grid_api_key_here


# -----------------------------------------------------------------------------
# 5. VOICE RECEPTIONIST (Twilio)
# -----------------------------------------------------------------------------

# Twilio Account SID — found in Twilio Console dashboard
# Format: ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REQUIRED
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Auth Token — found in Twilio Console dashboard (keep secret!)
# REQUIRED
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# The Symphony business phone number provisioned in Twilio.
# Format: E.164  e.g.  +18005551234
# REQUIRED
SYMPHONY_PHONE=+1XXXXXXXXXX


# -----------------------------------------------------------------------------
# 6. D-TOOLS CLOUD
# -----------------------------------------------------------------------------

# D-Tools Cloud API key for project and inventory integration.
# Obtain from: D-Tools Cloud Settings > Integration > Developer > API Keys
# REQUIRED
DTOOLS_API_KEY=your_dtools_api_key_here

# D-Tools Cloud REST API base URL.
# Only change this if D-Tools issues a new API version.
# Default: https://api.d-tools.com/v2
DTOOLS_BASE_URL=https://api.d-tools.com/v2

# D-Tools portal login (for /dtools_auto create and import browser automation)
# OPTIONAL — required only for autonomous browser create/import
DTOOLS_USERNAME=your@email.com
DTOOLS_PASSWORD=your_password


# -----------------------------------------------------------------------------
# 7. TELEGRAM BOTS — Symphony Ops Team
# -----------------------------------------------------------------------------
# Each team member has their own bot. Create via @BotFather:
#   /newbot → "Bob - Symphony" → pick a username like @SymphonyBobBot
#   Repeat for Betty and Beatrice
#
# Then create a Telegram group "Symphony Ops" and add all bots.

# Bob's bot token (main orchestrator)
# REQUIRED
TELEGRAM_BOT_TOKEN=your_bob_bot_token_here

# Betty's bot token (research & documentation)
# OPTIONAL — only if running Betty's bot
BETTY_BOT_TOKEN=your_betty_bot_token_here

# Beatrice's bot token (proposals & commissioning)  
# OPTIONAL — only if running Beatrice's bot
BEATRICE_BOT_TOKEN=your_beatrice_bot_token_here

# Your personal Telegram chat ID (owner/admin).
# Steps: message @userinfobot on Telegram → it replies with your chat ID.
# This restricts bot commands to only your account.
# Format: integer  e.g.  123456789
# REQUIRED
TELEGRAM_OWNER_CHAT_ID=123456789

# Optional direct chat target used by some autonomous tools.
# If blank, tools fall back to TELEGRAM_OWNER_CHAT_ID.
TELEGRAM_CHAT_ID=

# Symphony Ops group chat ID (for team updates)
# Steps: Add bots to group → send /whoami → note the chat_id
# OPTIONAL
SYMPHONY_OPS_CHAT_ID=

# Confidence gate for autonomous recovery autopilot (0.0-1.0).
# Recommended: 0.80 (only high-confidence playbooks auto-apply)
AUTOPILOT_CONFIDENCE_THRESHOLD=0.80


# -----------------------------------------------------------------------------
# 8. HOME ASSISTANT & MQTT
# -----------------------------------------------------------------------------

# Full URL to your Home Assistant instance (include port if non-standard).
# Examples:
#   http://192.168.1.50:8123       (local HA OS / Container)
#   http://homeassistant.local:8123
#   https://ha.yourdomain.com      (Nabu Casa / reverse proxy)
# REQUIRED
HA_URL=http://192.168.1.XXX:8123

# Home Assistant Long-Lived Access Token.
# Steps: HA → Profile → Security → Long-Lived Access Tokens → Create token
# REQUIRED
HA_TOKEN=your_ha_long_lived_access_token_here

# IP or hostname of your MQTT broker (usually the same host as HA or a
# dedicated broker like Mosquitto).
# REQUIRED
MQTT_BROKER=192.168.1.XXX

# MQTT broker port.
# Default: 1883 (unencrypted)  |  8883 (TLS)
MQTT_PORT=1883

# MQTT credentials — leave blank if your broker allows anonymous connections.
# OPTIONAL
MQTT_USERNAME=
MQTT_PASSWORD=


# -----------------------------------------------------------------------------
# 9. EMAIL / BUILDING CONNECTED (Zoho Mail)
# -----------------------------------------------------------------------------

# Symphony work email for inbox monitoring and BuildingConnected bids.
SYMPHONY_EMAIL=info@symphonysh.com

# Zoho Mail App Password
# Get at: Zoho Mail > Settings > Security > App Passwords
# REQUIRED for email features
SYMPHONY_EMAIL_PASSWORD=your_zoho_app_password_here

# Zoho IMAP settings (these are the defaults)
ZOHO_IMAP_SERVER=imappro.zoho.com
ZOHO_IMAP_PORT=993

# Zoho SMTP for sending (e.g. Claude task notifications to info@symphonysh.com)
# Default: smtp.zoho.com:587
# ZOHO_SMTP_SERVER=smtp.zoho.com

# Zoho OAuth2 (required for Calendar API, optional for enhanced Mail API)
# Get credentials at: https://api-console.zoho.com/
# Scopes needed: ZohoCalendar.event.ALL, ZohoMail.messages.ALL
ZOHO_CLIENT_ID=your_client_id
ZOHO_CLIENT_SECRET=your_client_secret
ZOHO_REFRESH_TOKEN=your_refresh_token

# Zoho Calendar UID for Bob's scheduling
# Get it from: https://calendar.zoho.com → Settings → Calendar → Show UID
ZOHO_CALENDAR_UID=your_calendar_uid

# Optional: Zoho Account ID (for enhanced mail features)
# ZOHO_ACCOUNT_ID=your_account_id


# -----------------------------------------------------------------------------
# 10. SUPABASE (Central Database)
# -----------------------------------------------------------------------------

# Supabase project URL
# Get at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (safe for client-side)
SUPABASE_KEY=your_anon_key_here

# Supabase service role key (server-side only, full access)
# NEVER expose this in client code
SUPABASE_SERVICE_KEY=your_service_role_key_here


# -----------------------------------------------------------------------------
# 11. GITHUB (Automation & Webhooks)
# -----------------------------------------------------------------------------

# GitHub Personal Access Token for API access
# Get at: https://github.com/settings/tokens
# Scopes needed: repo, workflow
GITHUB_TOKEN=ghp_your_token_here

# GitHub repo for webhooks (optional)
GITHUB_REPO=yourusername/AI-Server


# -----------------------------------------------------------------------------
# 12. X (TWITTER) — @symphonysmart
# -----------------------------------------------------------------------------
# Free tier: 500 posts/month via API v2
# Get keys at: https://developer.x.com/en/portal/dashboard
# 1. Create project + app
# 2. Set app permissions to "Read and Write"
# 3. Enable OAuth 1.0a
# 4. Regenerate tokens AFTER changing permissions

# API Key and Secret (from app "Keys and tokens" page)
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here

# Access Token and Secret (from app "Keys and tokens" page)
# Must be generated AFTER setting Read+Write permissions
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# X handle for reference
X_HANDLE=@symphonysmart


# -----------------------------------------------------------------------------
# 10. PER-SERVICE LOG LEVELS
# -----------------------------------------------------------------------------
# Valid values: error | warn | info | debug | trace
# Defaults to "info" if not set.

OPENCLAW_LOG_LEVEL=info
VOICE_LOG_LEVEL=info
DTOOLS_LOG_LEVEL=info
TELEGRAM_LOG_LEVEL=info
HA_LOG_LEVEL=info


# -----------------------------------------------------------------------------
# 13. NOTIFICATIONS (iMessage via AppleScript bridge)
# -----------------------------------------------------------------------------

# Channel: "imessage" or "console" (default: console)
NOTIFICATION_CHANNEL=console

# Recipient phone number for iMessage notifications (e.g. +15551234567)
# Used by notification-hub and imessage-server.py on the host
OWNER_PHONE_NUMBER=+15551234567

# iMessage bridge URL — the host-side AppleScript HTTP server
# Default in docker-compose: http://host.docker.internal:8199
# Only override for local dev outside Docker
# IMESSAGE_BRIDGE_URL=http://host.docker.internal:8199


# -----------------------------------------------------------------------------
# 14. POLYMARKET TRADING BOT
# -----------------------------------------------------------------------------

# Polymarket wallet private key (64 hex chars, no 0x prefix)
# Export from Polymarket settings or your wallet
# REQUIRED
POLY_PRIVATE_KEY=your_private_key_here

# Polymarket Safe address (from polymarket.com/settings)
# REQUIRED
POLY_SAFE_ADDRESS=0xYourSafeAddress

# Builder Program credentials (for gasless trading)
# Get at: polymarket.com/settings?tab=builder
# OPTIONAL but recommended
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=

# Default position size in USDC
POLY_DEFAULT_SIZE=10.0

# Maximum total portfolio exposure in USDC
POLY_MAX_EXPOSURE=100.0

# Bot log level
POLY_LOG_LEVEL=info

# Redis URL for TA signal sidecar communication
# Automatically injected via docker-compose; only set manually for local dev
# REDIS_URL=redis://localhost:6379

# Debate engine model override (falls back to CONDUCTOR_MODEL above)
# DEBATE_MODEL=claude-3-5-sonnet-20241022
