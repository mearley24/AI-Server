.DS_Store
.venv/
__pycache__/
*.pyc
logs/
*.log
backups/
**/last_approval_decision.txt
**/.env
**/.env.bak
orchestrator/state/api_key.txt
knowledge/Extracted_Knowledge/
knowledge/state/
knowledge/manual_vault/
knowledge/reports/manual_fetch_queue.csv

# Heartbeat reports (local only)
heartbeat_reports/*.json

# Xcode user-local workspace state (never share)
**/*.xcodeproj/project.xcworkspace/xcuserdata/
**/*.xcodeproj/xcuserdata/
**/*.xcworkspace/xcuserdata/

# --- Runtime / machine-local data (Bob — keep files on disk, not in git) ---
# SQLite and sidecars
data/**/*.db
data/**/*.db-shm
data/**/*.db-wal
data/**/*.db.bak.*

# Network watch + intake (updated by daemons)
data/network_watch/
data/intake_uploads/
data/bluebubbles/attachments/
data/manual_digest/

# Transcript drops, polymarket live state, OpenClaw live exports
data/transcripts/
# Broad JSON ignore (keep tracked placeholder)
data/**/*.json
!data/.gitkeep
data/polymarket/*.json
data/polymarket/*.csv
data/notes_index.json
data/openclaw/AGENT_LEARNINGS_LIVE.md
data/openclaw/patterns.json

# Large proposal PDFs in data/ (export artifacts; not source code)
data/proposals/*.pdf

# Intel + email SQLite trees (paths beyond *.db if added)
data/intel_feeds/
data/email-monitor/

# --- Machine-local / experiments (Bob or M2 — not shared via this repo) ---
symphonysh-web/
redis/
knowledge/cortex/

# Root knowledge/ is markdown/json/scripts — not a pip-style package (avoid IDE stubs)
knowledge/__init__.py
knowledge/hardware/__init__.py
scratch/
.cursor/local/

# Cursor prompt drafts (tracked prompts stay as single files; part2 / perplexity scratch stay local)
.cursor/prompts/*-part2.md
.cursor/prompts/perplexity-next-level*.md
.cursor/prompts/close-the-loop-part*.md
polymarket-bot/vpn/
.backups/
# SQLite journal files (anywhere)
*.db-journal
*.db-wal
data/backups*.tar.gz
# Local venv for iMessage bridge (scripts/install-imessage-deps.sh)
.venv-imessage/
models/
data/audio_intake/worker.log
data/audio_intake/launchd.*.log
data/audio_intake/processing/
data/audio_intake/processed/
data/audio_intake/failed/
data/audio_intake/incoming/
data/audio_intake/.worker.lock

# Task runner runtime state (scripts/task_runner.py writes these every tick)
data/task_runner/.runner.lock
data/task_runner/launchd.out.log
data/task_runner/launchd.err.log

# Runtime / watchdog noise
data/task_runner/*
ops/verification/*preflight*

# Vault — key file lives outside repo; DB and audit log are local data
data/vault/vault.key
data/vault/*.key
.env.backup*
*.env.backup*
