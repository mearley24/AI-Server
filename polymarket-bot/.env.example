# Polymarket Trading Bot — Environment Variables
# Copy to .env and fill in your values.

# ── Dry run mode — observe only, no real orders (default: true) ────
# Set to false when your Polymarket account is funded and ready
POLY_DRY_RUN=true

# ── Observer-only mode (default: true) ─────────────────────────────
# Strategies scan markets and log signals but skip ALL order placement
# (neither paper nor live orders).  Set to false to enable paper trading.
POLY_OBSERVER_ONLY=true

# ── Simulation-only mode (default: false) ───────────────────────────
# Polymarket paper trades active; Kraken/crypto market maker disabled.
# To enable: set POLY_OBSERVER_ONLY=false, POLY_SIMULATION_ONLY=true
# Kraken market maker can be re-enabled alongside simulation by also setting:
#   KRAKEN_MM_ENABLED=true
#   CRYPTO_TRADING_ENABLED=true
POLY_SIMULATION_ONLY=false
# KRAKEN_MM_ENABLED=true
# CRYPTO_TRADING_ENABLED=true

# ── Polymarket credentials ──────────────────────────────────────────
POLY_PRIVATE_KEY=your_64_hex_char_private_key_here
POLY_SAFE_ADDRESS=your_polymarket_safe_address_here

# Builder Program (gasless orders) — optional
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=

# ── Trading limits ──────────────────────────────────────────────────
POLY_DEFAULT_SIZE=10.0
POLY_MAX_EXPOSURE=100.0

# ── Claude AI (for debate engine) ──────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Redis (for TA sidecar signals) ─────────────────────────────────
REDIS_URL=redis://redis:6379

# ── AccuWeather API key (free tier: 50 calls/day) ──────────────────
# Get at: https://developer.accuweather.com/
ACCUWEATHER_API_KEY=your_key_here

# ── Multi-platform — comma-separated list of enabled platforms ────
# Options: polymarket, kalshi, crypto
PLATFORMS_ENABLED=kalshi,crypto

# ── Kalshi (prediction markets — CFTC regulated) ────────────────
KALSHI_API_KEY_ID=your_kalshi_api_key_uuid_here
KALSHI_PRIVATE_KEY_PATH=/app/secrets/kalshi.key
KALSHI_ENVIRONMENT=demo
KALSHI_DRY_RUN=true

# ── Crypto (Kraken via CCXT) ────────────────────────────────────
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here
KRAKEN_DRY_RUN=true
CRYPTO_EXCHANGE=kraken

# ── BTC price feed source ──────────────────────────────────────
# Options: kraken (default, US-friendly), coinbase, binance (geoblocked in US)
BTC_FEED_SOURCE=kraken

# ── Notifications ─────────────────────────────────────────────────
# Channel: "imessage" or "console" (default: console)
NOTIFICATION_CHANNEL=console
# Recipient phone number for iMessage notifications (e.g. +15551234567)
OWNER_PHONE_NUMBER=

# ── Vault passphrase — used to encrypt/decrypt the credential vault ─
# Set this once, then all other sensitive keys are encrypted at rest
# POLY_VAULT_PASSPHRASE=your_strong_passphrase_here
