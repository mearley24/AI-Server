# Polymarket Trading Bot — Environment Variables
# Copy to .env and fill in your values.

# ── Polymarket credentials ──────────────────────────────────────────
POLY_PRIVATE_KEY=your_64_hex_char_private_key_here
POLY_SAFE_ADDRESS=your_polymarket_safe_address_here

# Builder Program (gasless orders) — optional
POLY_BUILDER_API_KEY=
POLY_BUILDER_API_SECRET=
POLY_BUILDER_API_PASSPHRASE=

# ── Trading limits ──────────────────────────────────────────────────
POLY_DEFAULT_SIZE=10.0
POLY_MAX_EXPOSURE=100.0

# ── Claude AI (for debate engine) ──────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Redis (for TA sidecar signals) ─────────────────────────────────
REDIS_URL=redis://redis:6379

# ── AccuWeather API key (free tier: 50 calls/day) ──────────────────
# Get at: https://developer.accuweather.com/
ACCUWEATHER_API_KEY=your_key_here

# ── Vault passphrase — used to encrypt/decrypt the credential vault ─
# Set this once, then all other sensitive keys are encrypted at rest
# POLY_VAULT_PASSPHRASE=your_strong_passphrase_here
